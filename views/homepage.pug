doctype html
html 
    head  
        title= `${title}`
        meta(name="viewport" content="width=device-width, initial-scale=1")
        link(rel="stylesheet", href="/css/style.css")
    body    
        h1 Weapons
        a(href=`/update-weapons`)= "Add to this table"
        if weapons && weapons.length
          table.weapon-table
            thead
              tr
                th Name
                th Price
                th Description
                th Action
            tbody
                each weapon in weapons
                    tr
                        td  #{weapon.properties.name}
                        td #{weapon.properties.price} $
                        td #{weapon.properties.use_description}
                        td
                          a(href=`/update-weapons/${weapon.id}`) update
        else
            p No weapons found. Waiting for weapons you can use our new one. The "daisy", to use it, give it to your opponent, it may stun him so you can make your declaration. Good luck. If you already used it on someone, you can still use it again, it will up its affection bar (except if he's allergic to flowers...).
        
